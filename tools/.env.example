# Copy this file to tools/.env and fill in your values.
# .env is gitignored — never commit it.

# Anthropic API key — enables real Claude responses in the mock server
# and auto-provisioning via deploy.sh
ANTHROPIC_KEY=sk-ant-...

# WiFi credentials — used by deploy.sh to auto-provision the device after flash
WIFI_SSID=YourNetworkName
WIFI_PASS=YourPassword

# mDNS hostname — device will be reachable at http://<HOSTNAME>.local
# Optional; defaults to "dustgate" if omitted.
HOSTNAME=dustgate
