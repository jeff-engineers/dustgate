# =============================================================================
# DustGate — .gitignore
# =============================================================================

# ── PlatformIO ───────────────────────────────────────────────────────────────
.pio/
.pio.nosync/
# Keep platformio.ini, extra_script.py, and source; ignore generated artifacts

# ── Arduino IDE temp / build ──────────────────────────────────────────────────
build/
*.elf
*.bin
*.hex
*.map
*.bak

# Arduino libraries — managed by PlatformIO lib_deps, not checked in
libraries/

# ── Angular (dustgate-ui/) ────────────────────────────────────────────────────
dustgate-ui/node_modules/
dustgate-ui/dist/
dustgate-ui/.angular/
dustgate-ui/.sass-cache/
dustgate-ui/*.js.map

# ── Node (tools/) ────────────────────────────────────────────────────────────
tools/node_modules/
# Secrets — copy tools/.env.example → tools/.env and fill in values; never commit .env
tools/.env

# ── LittleFS data dir — generated by deploy.sh, not source ──────────────────
# Uncomment the line below if you want to exclude pre-built UI from the repo.
# linear_actuator/data/

# ── Angular lock file (delete this line if you want reproducible CI installs) ─
dustgate-ui/package-lock.json

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ── iCloud ────────────────────────────────────────────────────────────────────
*.icloud

# ── Editor ───────────────────────────────────────────────────────────────────
# .vscode/ contains absolute paths with the local username — don't share
.vscode/
*.swp
*.swo
*~
.idea/
