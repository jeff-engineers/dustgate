# Copy this file to .env.local, fill in your values, then run `vercel dev`
# from the repo root to test the Vercel demo (including the /api/claude
# serverless function) locally without deploying.
#
# .env.local is gitignored — never commit it.
#
# Fastest way to populate it: `vercel env pull .env.local` grabs everything
# below straight from your Vercel project (requires the Vercel CLI + linked
# project). This example exists so the required vars are documented even if you
# set them by hand.

# ── Required ────────────────────────────────────────────────────────────────
# Without these three, api/claude.ts fails: the ANTHROPIC_KEY check returns a
# 500, and Redis.fromEnv() throws at module load if either UPSTASH_* is missing
# (crashing the function before your request reaches the handler).

# Anthropic API key the proxy forwards with. NOTE: the var is ANTHROPIC_KEY,
# not ANTHROPIC_API_KEY.
ANTHROPIC_KEY=sk-ant-...

# Upstash Redis REST credentials — back the rate limiters (Redis.fromEnv()).
# Use a throwaway/local Upstash instance if you don't want local testing to
# touch production's daily rate-limit buckets.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── Optional ────────────────────────────────────────────────────────────────
# All safe to leave unset — the corresponding feature just disables itself and
# you're treated as a normal public visitor (global 200/day, per-IP 25/day).

# Bypasses all rate limits when sent as the request's accessCode field.
ADMIN_ACCESS_CODE=

# Routed through a separate, generous bucket (dg:guest) instead of the public
# buckets — hand this to interviewers so their traffic is isolated.
GUEST_ACCESS_CODE=

# Optional ISO 8601 timestamp; after it passes, GUEST_ACCESS_CODE silently
# stops working (falls back to public limits). Malformed value fails open.
GUEST_ACCESS_CODE_EXPIRES=
